# Mock infra (Phase 1 local) — Python 3.12 .venv (npm run setup)
INFOTOOLS_MOCK_INFRA_PORT=19427
INFOTOOLS_MOCK_R2_ROOT=./data/mock-r2
INFOTOOLS_PUBLIC_BASE_URL=http://127.0.0.1:19427
INFOTOOLS_MOCK_AI=1

# Web dev (Vite)
VITE_API_BASE_URL=http://127.0.0.1:19427

# Phase 3 — RunPod worker (set on RunPod endpoint, not in browser)
# INFOTOOLS_STORAGE_PROVIDER=r2
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
# R2_PUBLIC_BASE_URL=https://YOUR_R2_PUBLIC_DOMAIN

# Phase 3 — Cloudflare Pages Functions (apps/web/.dev.vars or wrangler secrets)
# RUNPOD_API_KEY=
# RUNPOD_VOCAL_REMOVER_ENDPOINT=https://api.runpod.ai/v2/YOUR_ENDPOINT_ID
# ADMIN_TOKEN=

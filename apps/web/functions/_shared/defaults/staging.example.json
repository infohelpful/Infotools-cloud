{
  "id": "staging",
  "label": "스테이징 (Pages Functions + R2 + RunPod)",
  "apiBase": "",
  "storage": {
    "provider": "r2",
    "mode": "presigned",
    "bucket": "YOUR_STAGING_BUCKET",
    "publicBaseUrl": "https://YOUR_STAGING_R2_PUBLIC_DOMAIN"
  },
  "inference": {
    "provider": "runpod",
    "mode": "edge-proxy",
    "endpoints": {
      "vocal-remover": "https://api.runpod.ai/v2/YOUR_STAGING_ENDPOINT_ID"
    }
  }
}
